PORT=5000
NODE_ENV=development

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

JWT_SECRET=
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=30d

OTP_LENGTH=6
OTP_EXPIRES_IN=10m
OTP_MAX_ATTEMPTS=5
KU_EMAIL_DOMAIN=ku.edu.np
# Database direct connection for migrations (Settings -> Database -> Connection string -> URI)
DATABASE_URL=

# Optional Redis-backed auth user cache (falls back to in-memory when unset)
REDIS_URL=

# Student OTP email delivery (console fallback in non-production when disabled)
OTP_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Admin auth: set ADMIN_PASSWORD_LOGIN_ENABLED=true only for local/demo
ADMIN_PASSWORD_LOGIN_ENABLED=false
ADMIN_TOTP_SECRET=

# Phase 4 resume upload (Milestone 3+)
RESUME_MAX_BYTES=5242880
RESUME_STORAGE_BUCKET=resumes

# Phase 4 async analysis worker (Milestone 4+; required in production for uploads)
# REDIS_URL=redis://localhost:6379
RESUME_ANALYSIS_QUEUE_CONCURRENCY=3
RESUME_ANALYSIS_JOB_ATTEMPTS=3
RESUME_ANALYSIS_BACKOFF_MS=5000
